# =============================================================================
# INFERENCE RULES (OWL)
# =============================================================================

# Si deux projets sont dans la même catégorie → ils sont sémantiquement liés
syntonie:Category rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty syntonie:containsProject ;
    owl:onClass syntonie:Project ;
    owl:cardinality 1
] .

# Transitivity: Si A est voisin de B et B est voisin de C, alors A est lointainement voisin de C
syntonie:hasSemanticNeighbor a owl:TransitiveProperty .

# Symmetry: Si A est voisin de B, B est voisin de A
syntonie:hasSemanticNeighbor a owl:SymmetricProperty .

# =============================================================================
# METADATA
# =============================================================================

syntonie:Ontology a owl:Ontology ;
    rdfs:label "Ontologie Syntonie"@fr, "Syntonie Ontology"@en ;
    dcterms:title "Ontologie Syntonie — Architecture Sémantique v1.0"@fr ;
    dcterms:creator "Nicolas — ASBL Syntonie" ;
    dcterms:created "2026-03-27"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "1.0" ;
    rdfs:comment "This ontology supports 5-star open data compliance for Syntonie's semantic architecture."@en .
