# =============================================================================
# SYNTONIE — ONTOLOGIE SÉMANTIQUE COMPLÈTE
# =============================================================================
# ASBL Syntonie — Architecture Sémantique v1.1
# Date: 2026-03-27
# Namespace: https://syntonie.be/ns/
# Licence: CC0 1.0 Universal
# Alignement: 5-star Open Data ★★★★★
# =============================================================================

@prefix syntonie: <https://syntonie.be/ns/> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix schema:   <https://schema.org/> .
@prefix xkos:     <http://rdf-vocabulary.ddialliance.org/xkos#> .
@prefix prov:     <http://www.w3.org/ns/prov#> .
@prefix geo:      <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# CLASSES
# =============================================================================

syntonie:Entry          a rdfs:Class ; rdfs:label "Point d'entrée"@fr .
syntonie:Category       a rdfs:Class ; rdfs:label "Catégorie"@fr .
syntonie:Project        a rdfs:Class ; rdfs:label "Projet"@fr .
syntonie:Role           a rdfs:Class ; rdfs:label "Rôle"@fr .
syntonie:Vocabulary     a rdfs:Class ; rdfs:label "Vocabulaire"@fr .
syntonie:EmotionalStage a rdfs:Class ; rdfs:label "Étape émotionnelle"@fr .
syntonie:SemanticNeighbor a rdfs:Class ; rdfs:label "Voisin sémantique"@fr .
syntonie:CallToAction   a rdfs:Class ; rdfs:label "Appel à l'action"@fr .
syntonie:StageType      a rdfs:Class ; rdfs:label "Type d'étape"@fr .

syntonie:Recognition a syntonie:StageType ; rdfs:label "Recognition"@fr .
syntonie:Community   a syntonie:StageType ; rdfs:label "Communauté"@fr .
syntonie:Action      a syntonie:StageType ; rdfs:label "Appel à l'action"@fr .

# =============================================================================
# PROPRIÉTÉS
# =============================================================================

syntonie:suggestsCategory    a rdf:Property ; rdfs:domain syntonie:Entry ; rdfs:range syntonie:Category .
syntonie:hasRole             a rdf:Property ; rdfs:domain syntonie:Entry ; rdfs:range syntonie:Role .
syntonie:prioritizesVocabulary a rdf:Property ; rdfs:domain syntonie:Role ; rdfs:range syntonie:Vocabulary .
syntonie:hasVocabulary       a rdf:Property ; rdfs:domain syntonie:Category ; rdfs:range syntonie:Vocabulary .
syntonie:containsProject     a rdf:Property ; rdfs:domain syntonie:Category ; rdfs:range syntonie:Project .
syntonie:hasSemanticNeighbor a rdf:Property ; rdfs:domain syntonie:Project ; rdfs:range syntonie:SemanticNeighbor .
syntonie:neighborTarget      a rdf:Property ; rdfs:domain syntonie:SemanticNeighbor ; rdfs:range syntonie:Project .
syntonie:proximityScore      a rdf:Property ; rdfs:domain syntonie:SemanticNeighbor ; rdfs:range xsd:decimal .
syntonie:proximityReason     a rdf:Property ; rdfs:domain syntonie:SemanticNeighbor ; rdfs:range rdfs:Literal .
syntonie:triggersStage       a rdf:Property ; rdfs:domain syntonie:Project ; rdfs:range syntonie:EmotionalStage .
syntonie:stageType           a rdf:Property ; rdfs:domain syntonie:EmotionalStage ; rdfs:range syntonie:StageType .
syntonie:stageContent        a rdf:Property ; rdfs:domain syntonie:EmotionalStage ; rdfs:range rdfs:Literal .
syntonie:hasCallToAction     a rdf:Property ; rdfs:domain syntonie:Project ; rdfs:range syntonie:CallToAction .
syntonie:ctaType             a rdf:Property ; rdfs:domain syntonie:CallToAction ; rdfs:range rdfs:Literal .
syntonie:ctaTarget           a rdf:Property ; rdfs:domain syntonie:CallToAction ; rdfs:range rdfs:Literal .
syntonie:status              a rdf:Property ; rdfs:range [ "active" , "archived" , "prototype" ] .

# =============================================================================
# VOCABULAIRES
# =============================================================================

syntonie:vocab-making a syntonie:Vocabulary ;
    skos:prefLabel "making"@fr , "making"@en ;
    skos:hiddenLabel "fabrication", "prototypage", "conception", "makers", "fablab", "bois", "laser", "impression 3D", "CNC", "travail du bois", "bidouille"@fr ;
    skos:hiddenLabel "fabrication", "prototyping", "design", "makers", "fablab", "wood", "laser", "3D printing", "CNC", "woodwork", "tinkering"@en .

syntonie:vocab-neurodivergence a syntonie:Vocabulary ;
    skos:prefLabel "neurodiversité"@fr , "neurodiversity"@en ;
    skos:hiddenLabel "autisme", "dyslexie", "TDAH", "neuroatypique", "cerveau", "cognition", "neuro-inclusivité", "différences cognitives"@fr ;
    skos:hiddenLabel "autism", "dyslexia", "ADHD", "neuroatypical", "brain", "cognition", "neuro-inclusivity", "cognitive differences"@en .

syntonie:vocab-gouvernance a syntonie:Vocabulary ;
    skos:prefLabel "gouvernance"@fr , "governance"@en ;
    skos:hiddenLabel "prise de décision", "horizontalité", "autonomie", "Holacratie", "conseil", "délibération", "participatif", "transparence"@fr ;
    skos:hiddenLabel "decision making", "horizontality", "autonomy", "Holacracy", "council", "deliberation", "participative", "transparency"@en .

syntonie:vocab-inclusion a syntonie:Vocabulary ;
    skos:prefLabel "inclusion"@fr , "inclusion"@en ;
    skos:hiddenLabel "accessibilité", "diversité", "handicap", " welcoming", "belonging", "tissu social", "quartier", "proximité"@fr ;
    skos:hiddenLabel "accessibility", "diversity", "disability", "welcoming", "belonging", "social fabric", "neighborhood", "proximity"@en .

syntonie:vocab-autonomie a syntonie:Vocabulary ;
    skos:prefLabel "autonomie"@fr , "autonomy"@en ;
    skos:hiddenLabel "indépendance", "self-sufficiency", "empowerment", "souveraineté", "DIY", "vert", "durable", "permaculture"@fr ;
    skos:hiddenLabel "independence", "self-sufficiency", "empowerment", "sovereignty", "DIY", "green", "sustainable", "permaculture"@en .

syntonie:vocab-open-source a syntonie:Vocabulary ;
    skos:prefLabel "open source"@fr , "open source"@en ;
    skos:hiddenLabel "libre", "partagé", "CC0", "GPL", "communauté", "Europe", "mobilité", "réseau"@fr ;
    skos:hiddenLabel "free", "shared", "CC0", "GPL", "community", "Europe", "mobility", "network"@en .

syntonie:vocab-fablab a syntonie:Vocabulary ;
    skos:prefLabel "fablab"@fr , "fablab"@en ;
    skos:hiddenLabel "fabrication numérique", "laser", "CNC", "imprimante 3D", "makerspace", "équipement", "atelier partagé"@fr ;
    skos:hiddenLabel "digital fabrication", "laser", "CNC", "3D printer", "makerspace", "equipment", "shared workshop"@en .

syntonie:vocab-gamification a syntonie:Vocabulary ;
    skos:prefLabel "gamification"@fr , "gamification"@en ;
    skos:hiddenLabel "jeu", "escape", "ludique", "serious game", "play", "plateau", "immersif", "sensibilisation"@fr ;
    skos:hiddenLabel "game", "escape", "playful", "serious game", "play", "board", "immersive", "awareness"@en .

syntonie:vocab-pedagogie a syntonie:Vocabulary ;
    skos:prefLabel "pédagogie"@fr , "pedagogy"@en ;
    skos:hiddenLabel "éducation", "formation", "ateliers", "sensibilisation", "apprentissage", "jeunes", "scolaire"@fr ;
    skos:hiddenLabel "education", "training", "workshops", "awareness", "learning", "youth", "school"@en .

syntonie:vocab-urbanisme a syntonie:Vocabulary ;
    skos:prefLabel "urbanisme"@fr , "urban planning"@en ;
    skos:hiddenLabel "ville", "quartier", "espace public", "bâtiment", "mobilité", "vélo", "urbain", "biodiversité"@fr ;
    skos:hiddenLabel "city", "neighborhood", "public space", "building", "mobility", "bike", "urban", "biodiversity"@en .

syntonie:vocab-solidarite a syntonie:Vocabulary ;
    skos:prefLabel "solidarité"@fr , "solidarity"@en ;
    skos:hiddenLabel "humanitaire", "entraide", "RDC", "Kesho Kongo", "corona", "masques", "visières", "malnutrition"@fr ;
    skos:hiddenLabel "humanitarian", "mutual aid", "DRC", "Kesho Kongo", "corona", "masks", "visors", "malnutrition"@en .

syntonie:vocab-artisanat a syntonie:Vocabulary ;
    skos:prefLabel "artisanat"@fr , "craftsmanship"@en ;
    skos:hiddenLabel "savoir-faire", "manuel", "tradition", "vélo vintage", "mobilier", "menuiserie"@fr ;
    skos:hiddenLabel "know-how", "manual", "tradition", "vintage bike", "furniture", "carpentry"@en .

# =============================================================================
# RÔLES (Level 0)
# =============================================================================

syntonie:role-maker a syntonie:Role ;
    syntonie:prioritizesVocabulary syntonie:vocab-making, syntonie:vocab-fablab, syntonie:vocab-open-source ;
    skos:prefLabel "Maker"@fr , "Maker"@en ;
    skos:definition "Personne qui aime créer, prototyper,动手 avec les outils"@fr .

syntonie:role-leader a syntonie:Role ;
    syntonie:prioritizesVocabulary syntonie:vocab-gouvernance, syntonie:vocab-inclusion, syntonie:vocab-autonomie ;
    skos:prefLabel "Porteur de projet"@fr , "Project Lead"@en ;
    skos:definition "Personne qui porte un projet et cherche structuration"@fr .

syntonie:role-partner a syntonie:Role ;
    syntonie:prioritizesVocabulary syntonie:vocab-open-source, syntonie:vocab-fablab, syntonie:vocab-inclusion ;
    skos:prefLabel "Partenaire"@fr , "Partner"@en ;
    skos:definition "Organisation ou individu intéressé par collaboration"@fr .

syntonie:role-evaluator a syntonie:Role ;
    syntonie:prioritizesVocabulary syntonie:vocab-gouvernance, syntonie:vocab-inclusion, syntonie:vocab-autonomie ;
    skos:prefLabel "Évaluateur"@fr , "Evaluator"@en ;
    skos:definition "Évaluateur de projets (Erasmus+, subsides, etc.)"@fr .

# =============================================================================
# CATÉGORIES (Level 1)
# =============================================================================

syntonie:cat-social a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-inclusion, syntonie:vocab-solidarite ;
    syntonie:suggestsCategory syntonie:cat-autonomie, syntonie:cat-making ;
    dcterms:title "Social & Communautaire"@fr ;
    schema:headline "Renforcer le tissu social local par l'intelligence collective."@fr ;
    syntonie:containsProject syntonie:proj-bricole-picole, syntonie:proj-actions-corona, syntonie:proj-operation-speculoos, syntonie:proj-permablitz ;
    syntonie:status "active" .

syntonie:cat-pedagogie a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-pedagogie, syntonie:vocab-fablab ;
    syntonie:suggestsCategory syntonie:cat-making, syntonie:cat-gamification ;
    dcterms:title "Pédagogie & Formation"@fr ;
    schema:headline "Sensibiliser aux sciences et technologies par la pratique."@fr ;
    syntonie:containsProject syntonie:proj-fablab-mobile, syntonie:proj-fab-ecole, syntonie:proj-flopacademy, syntonie:proj-artisans-2-0 ;
    syntonie:status "active" .

syntonie:cat-gamification a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-gamification, syntonie:vocab-pedagogie ;
    syntonie:suggestsCategory syntonie:cat-fablab, syntonie:cat-social ;
    dcterms:title "GameLab"@fr ;
    schema:headline "Le jeu comme outil d'apprentissage et de cohésion."@fr ;
    syntonie:containsProject syntonie:proj-enigmaker, syntonie:proj-escape-box-biodiversite, syntonie:proj-matongray, syntonie:proj-soirees-jeux, syntonie:proj-cabinet-etrange ;
    syntonie:status "active" .

syntonie:cat-recherche a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-open-source, syntonie:vocab-pedagogie ;
    syntonie:suggestsCategory syntonie:cat-fablab, syntonie:cat-making ;
    dcterms:title "Recherche & Rayonnement Européen"@fr ;
    schema:headline "Innovation technique et collaborations transfrontalières."@fr ;
    syntonie:containsProject syntonie:proj-passeport-maker, syntonie:proj-chic-2-0, syntonie:proj-reseau-vulca, syntonie:proj-allo-ia, syntonie:proj-invisible-play ;
    syntonie:status "active" .

syntonie:cat-prototypage a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-making, syntonie:vocab-artisanat ;
    syntonie:suggestsCategory syntonie:cat-social, syntonie:cat-fablab ;
    dcterms:title "Prototypage & Réalisations"@fr ;
    schema:headline "Concevoir, prototyper, réaliser."@fr ;
    syntonie:containsProject syntonie:proj-eco-design, syntonie:proj-mobilier, syntonie:proj-micro-projets ;
    syntonie:status "active" .

syntonie:cat-fablab a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-fablab, syntonie:vocab-making ;
    syntonie:suggestsCategory syntonie:cat-pedagogie, syntonie:cat-gamification, syntonie:cat-recherche ;
    dcterms:title "Fablab"@fr ;
    schema:headline "Des outils pour tous, par tous."@fr ;
    syntonie:containsProject syntonie:proj-council-of-makers, syntonie:proj-fablab-mobile, syntonie:proj-fab-ecole ;
    syntonie:status "active" .

syntonie:cat-gouvernance a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-gouvernance, syntonie:vocab-inclusion ;
    syntonie:suggestsCategory syntonie:cat-fablab, syntonie:cat-social ;
    dcterms:title "Gouvernance"@fr ;
    schema:headline "La structure est à nous. Le projet est à vous."@fr ;
    syntonie:containsProject syntonie:proj-council-of-makers ;
    syntonie:status "active" .

syntonie:cat-neurodivergence a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-neurodivergence, syntonie:vocab-urbanisme ;
    syntonie:suggestsCategory syntonie:cat-inclusion, syntonie:cat-recherche ;
    dcterms:title "Neurodiversité"@fr ;
    schema:headline "Chaque cerveau fonctionne différemment. Et c'est une force."@fr ;
    syntonie:containsProject syntonie:proj-invisible-play, syntonie:proj-allo-ia ;
    syntonie:status "active" .

syntonie:cat-autonomie a syntonie:Category ;
    syntonie:hasVocabulary syntonie:vocab-autonomie, syntonie:vocab-urbanisme ;
    syntonie:suggestsCategory syntonie:cat-social, syntonie:cat-prototypage ;
    dcterms:title "Autonomie & Durabilité"@fr ;
    schema:headline "Reprendre le pouvoir sur ce qu'on crée et consomme."@fr ;
    syntonie:containsProject syntonie:proj-permablitz, syntonie:proj-eco-design ;
    syntonie:status "active" .

# =============================================================================
# PROJETS (Level 2) — SOCIAL & COMMUNAUTAIRE
# =============================================================================

syntonie:proj-bricole-picole a syntonie:Project ;
    dcterms:identifier "bricole-picole" ;
    dcterms:title "Bricole & Picole"@fr ;
    dcterms:alternative "Soirées conviviales de bricolage et de partage"@fr ;
    dcterms:description "Soirées conviviales de bricolage et de partage ouvertes au voisinage, initialement lancées dans un garage à Ixelles. L'esprit: faire ensemble, boire ensemble, apprendre ensemble."@fr ;
    syntonie:status "active" ;
    dcterms:created "2012-01-01"^^xsd:date ;
    dcterms:spatial [ a geo:SpatialThing ; geo:location "Ixelles, Bruxelles" ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-soirees-jeux ;
        syntonie:proximityScore "0.8"^^xsd:decimal ;
        syntonie:proximityReason "Même format social et convivial"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-permablitz ;
        syntonie:proximityScore "0.6"^^xsd:decimal ;
        syntonie:proximityReason "Maker local et durable"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-actions-corona ;
        syntonie:proximityScore "0.4"^^xsd:decimal ;
        syntonie:proximityReason "Même esprit d'entraide de voisinage"@fr
    ] ;
    syntonie:hasCallToAction [
        a syntonie:CallToAction ;
        syntonie:ctaType "event" ;
        dcterms:title "Tu veux venir bricoler avec nous?"@fr ;
        syntonie:ctaTarget "/contact?context=bricole-picole"
    ] .

syntonie:proj-actions-corona a syntonie:Project ;
    dcterms:identifier "actions-corona" ;
    dcterms:title "Actions Corona"@fr ;
    dcterms:description "Production solidaire de 1500 visières de protection et 4500 masques en tissu pour le secteur médical et le personnel de première ligne, lors de la pandémie COVID-19."@fr ;
    syntonie:status "archived" ;
    dcterms:created "2020-03-01"^^xsd:date ;
    dcterms:modified "2020-06-30"^^xsd:date ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-operation-speculoos ;
        syntonie:proximityScore "0.7"^^xsd:decimal ;
        syntonie:proximityReason "Même esprit solidaire et humanitarian"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-bricole-picole ;
        syntonie:proximityScore "0.4"^^xsd:decimal ;
        syntonie:proximityReason "Fabrication locale et entraide"@fr
    ] .

syntonie:proj-operation-speculoos a syntonie:Project ;
    dcterms:identifier "operation-speculoos" ;
    dcterms:title "Opération Speculoos"@fr ;
    dcterms:description "Projet humanitaire de fabrication et vente de biscuits au profit de l'association Kesho Kongo pour lutter contre la malnutrition infantile en RDC. Une acción de solidarité internationale."@fr ;
    syntonie:status "active" ;
    dcterms:created "2021-01-01"^^xsd:date ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-actions-corona ;
        syntonie:proximityScore "0.7"^^xsd:decimal ;
        syntonie:proximityReason "Même espíritu d'entraide et fabrication solidaire"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-micro-projets ;
        syntonie:proximityScore "0.4"^^xsd:decimal ;
        syntonie:proximityReason "Fabrication et personnalisation (moules à biscuits)"@fr
    ] ;
    syntonie:hasCallToAction [
        a syntonie:CallToAction ;
        syntonie:ctaType "solidarity" ;
        dcterms:title "Tu veux participer à la prochaine fournée?"@fr ;
        syntonie:ctaTarget "/contact?context=operation-speculoos"
    ] .

syntonie:proj-permablitz a syntonie:Project ;
    dcterms:identifier "permablitz" ;
    dcterms:title "Permablitz"@fr ;
    dcterms:description "Ateliers de permaculture urbaine à Bruxelles. Transformation d'espaces négligés en potagers productifs grâce à l'intelligence collective."@fr ;
    syntonie:status "active" ;
    dcterms:created "2013-01-01"^^xsd:date ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-bricole-picole ;
        syntonie:proximityScore "0.6"^^xsd:decimal ;
        syntonie:proximityReason "Même format maker local et collaboratif"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-eco-design ;
        syntonie:proximityScore "0.5"^^xsd:decimal ;
        syntonie:proximityReason "Éco-design et durabilité"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-invisible-play ;
        syntonie:proximityScore "0.3"^^xsd:decimal ;
        syntonie:proximityReason "Urbanisme et espace vert"@fr
    ] .

# =============================================================================
# PROJETS (Level 2) — PÉDAGOGIE & FORMATION
# =============================================================================

syntonie:proj-fablab-mobile a syntonie:Project ;
    dcterms:identifier "fablab-mobile" ;
    dcterms:title "Fablab Mobile"@fr ;
    dcterms:alternative "Le fablab qui vient à toi"@fr ;
    dcterms:description "En 2018-2019, on a pris des camions et des vélos cargos. On a traversé Bruxelles. 12 700 jeunes ont découvert la fabrication numérique grâce à des ateliers mobiles."@fr ;
    syntonie:status "archived" ;
    dcterms:created "2018-01-01"^^xsd:date ;
    dcterms:modified "2019-12-31"^^xsd:date ;
    dcterms:spatial [ a geo:SpatialThing ; geo:location "Bruxelles, Belgique" ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-fab-ecole ;
        syntonie:proximityScore "0.9"^^xsd:decimal ;
        syntonie:proximityReason "Prolongement scolaire du Fablab Mobile"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-flopacademy ;
        syntonie:proximityScore "0.6"^^xsd:decimal ;
        syntonie:proximityReason "Public similaire (jeunes) et approche maker"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-reseau-vulca ;
        syntonie:proximityScore "0.4"^^xsd:decimal ;
        syntonie:proximityReason "Mobilité maker"@fr
    ] .

syntonie:proj-fab-ecole a syntonie:Project ;
    dcterms:identifier "fab-ecole" ;
    dcterms:title "Fab'École"@fr ;
    dcterms:description "Intégration de la culture maker en milieu scolaire, notamment à l'Athénée Charles Janssens, pour résoudre des défis locaux comme l'arrosage automatique d'un potager."@fr ;
    syntonie:status "archived" ;
    dcterms:created "2019-01-01"^^xsd:date ;
    dcterms:modified "2021-12-31"^^xsd:date ;
    dcterms:spatial [ a geo:SpatialThing ; geo:location "Athénée Charles Janssens, Bruxelles" ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-fablab-mobile ;
        syntonie:proximityScore "0.9"^^xsd:decimal ;
        syntonie:proximityReason "Même famille éducative et maker"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-flopacademy ;
        syntonie:proximityScore "0.7"^^xsd:decimal ;
        syntonie:proximityReason "Même approche pédagogique par le faire"@fr
    ] ;
    syntonie:hasSemanticNeighbor [
        syntonie:neighborTarget syntonie:proj-permablitz ;
        syntonie:proximityScore "0.4"^^xsd:decimal ;
        syntonie:proximityReason "Jardinage et potager scolaire"@fr
    ] .

syntonie:proj-flopacademy a syntonie:Project ;
    dcterms:identifier "flopacademy" ;
    dcterms:title "FlopAcademy / FlopCamp"@fr ;
    dcterms:description "Stages encourageant l'entrepreneuriat chez les jeunes par le prototypage rapide. L'échec est vu comme une étape d'apprentissage, pas un arrêt."@fr ;
    syntonie:status "active" ;
    dcterms:created "2019-01-01"^^xsd:date ;
    syntonie:hasSemanticNeighbor [
