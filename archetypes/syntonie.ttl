# =============================================================================
# MÉTADONNÉES DE L'ONTOLOGIE
# =============================================================================

syntonie:Ontology a owl:Ontology ;
    rdfs:label "Ontologie Syntonie"@fr , "Syntonie Ontology"@en ;
    dcterms:title "Ontologie Syntonie — Architecture Sémantique v1.0"@fr ;
    dcterms:creator "Nicolas — ASBL Syntonie" ;
    dcterms:created "2026-03-27"^^xsd:date ;
    dcterms:modified "2026-03-27"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    dcterms:format "text/turtle" ;
    owl:versionInfo "1.0" ;
    rdfs:comment "Cette ontologie supporte la conformité 5-star Open Data pour l'architecture sémantique de Syntonie. 22 projets documentés, 9 catégories, 4 rôles."@fr .

# =============================================================================
# RÈGLES D'INFÉRENCE (OWL)
# =============================================================================

# Transitivité: Si A est voisin de B et B est voisin de C, alors A est lointainement voisin de C
syntonie:hasSemanticNeighbor a owl:TransitiveProperty , owl:SymmetricProperty .

# Réciprocité des catégories: Si Category1 suggère Category2, alors Category2 peut suggérer Category1
syntonie:suggestsCategory a owl:SymmetricProperty .

# =============================================================================
# FIN DE L'ONTOLOGIE
# =============================================================================